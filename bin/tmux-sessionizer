#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
    selected="$1"
else
    selected=$(find ~ -maxdepth 4 -type d \
        ! -path "*/.git*" \
        ! -path "*/node_modules*" | fzf --prompt="> ")
fi

[ -z "$selected" ] && exit 0

selected_name=$(basename "$selected" | tr . _)

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
    tmux rename-window -t "$selected_name:1" scratch
    tmux new-window   -t "$selected_name:2" -n server -c "$selected"
    tmux new-window   -t "$selected_name:3" -n nvim   -c "$selected"
    tmux select-window -t "$selected_name:3"
fi

tmux switch-client -t "$selected_name" 2>/dev/null || tmux attach -t "$selected_name"
